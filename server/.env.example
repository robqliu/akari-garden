# Copy to server/.env (gitignored) and fill in.

# Get these from the Google Cloud Console: APIs & Services >
# Credentials > Create OAuth client ID, type "Web application". Add
# http://localhost:3000/api/auth/google/callback as an authorized
# redirect URI. Add yourself as a test user in the OAuth consent
# screen settings while the app is in "testing" mode.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Any long random string. Generate with: openssl rand -hex 32
# Used to HMAC-sign the OAuth state token and session cookie.
SESSION_SIGNING_KEY=

# Public origin of this API. Local dev: http://localhost:3000.
PUBLIC_API_URL=http://localhost:3000
