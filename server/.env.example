# Copy to server/.env and fill in. server/.env is gitignored.
#
# Get GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET from the Google Cloud
# Console: APIs & Services > Credentials > Create OAuth client ID, type
# "Web application". Add http://localhost:3000/api/auth/google/callback
# as an authorized redirect URI. While the app is in "testing" mode in
# the OAuth consent screen settings, add your own Google account as a
# test user.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Any long random string. Generate with e.g. `openssl rand -hex 32`.
# Rotating this invalidates every outstanding session.
SESSION_SIGNING_KEY=

# Public origin of the API. In dev this matches PORT below.
# In prod (Workers) this is the deployed worker's origin.
PUBLIC_API_URL=http://localhost:3000

# Optional. Defaults to 3000.
# PORT=3000
