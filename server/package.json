{
  "name": "@akari-garden/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/local/dev-server.ts",
    "dev:clean": "rm -f .dev.sqlite",
    "build": "wrangler deploy --dry-run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed-tasks": "tsx --env-file-if-exists=.env src/local/seed-tasks.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@hono/standard-validator": "^0.2.2",
    "@hono/zod-validator": "^0.8.0",
    "@js-temporal/polyfill": "^0.5.1",
    "better-sqlite3": "^12.10.0",
    "hono": "^4.12.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260522.1",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
